PORT=8787
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/localhero

# Privy — use your app’s JWKS URL from the Privy dashboard
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/YOUR_APP_ID/jwks.json
PRIVY_ISSUER=https://auth.privy.io
# PRIVY_AUDIENCE=
CORS_ORIGIN=http://localhost:5173

# Public URL for links returned to the client (avatar URLs). Use your deployed API origin in production.
PUBLIC_API_BASE_URL=http://localhost:8787

# 0G Storage (testnet defaults). Fund OG_0G_STORAGE_PRIVATE_KEY on the matching network.
OG_0G_EVM_RPC=https://evmrpc-testnet.0g.ai
OG_0G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# Required for POST /me/storage/upload and GET /storage/files/:rootHash
OG_0G_STORAGE_PRIVATE_KEY=0x_your_funded_testnet_wallet_private_key

# HERO ERC-20 — points → token redeem (POST /me/redeem). Deploy contracts/src/HeroToken.sol; grant MINTER_ROLE to this key.
HERO_TOKEN_ADDRESS=
HERO_TOKEN_MINTER_PRIVATE_KEY=
# Optional; defaults to OG_0G_EVM_RPC
# HERO_TOKEN_CHAIN_RPC=https://evmrpc-testnet.0g.ai
POINTS_PER_HERO_TOKEN=100
MIN_REDEEM_POINTS=100
HERO_CHAIN_ID=16602

# OpenAI-compatible LLM for creator educational quest drafts.
# Code calls: POST {OG_AI_API_URL}/chat/completions (see server/src/aiQuestDraft.ts).
# Examples:
#   - Third-party gateway: https://api.openai.com/v1  or  https://ai.gateway.lovable.dev/v1
#   - 0G Compute: use the OpenAI-compatible base URL from your 0G Compute inference setup
#     (https://docs.0g.ai/docs/developer-hub/building-on-0g/compute-network/inference).
# See docs/0G_ECOSYSTEM_GRANT.md — "Connecting quest-draft AI to 0G Compute".
OG_AI_API_URL=
OG_AI_API_KEY=
OG_AI_MODEL=google/gemini-2.0-flash-001
